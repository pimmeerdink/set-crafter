---
import { Button } from '@/components/ui/button'
import Checkbox from '@/components/Checkbox.astro'
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6" x-data="alpineData">
  <div>
    <div class="flex items-center border border-primary-foreground/20">
      <input
        type="text"
        x-model="url"
        placeholder="enter bandcamp url"
        class="flex-1 font-mono border-none text-primary-foreground text-xl px-4 py-1 outline-none bg-primary/80 focus:bg-primary"
        @keydown.enter="addItem"
      />

      <Button x-on:click="addItem" variant="link">add item</Button>
    </div>

    <!-- Profile loader: paste a bandcamp profile URL and seed from wishlist/collection -->
    <div class="mt-3 border border-primary-foreground/20">
      <div class="flex items-center border-b border-primary-foreground/20">
        <input
          type="text"
          x-model="profileUrl"
          placeholder="…or paste your bandcamp profile"
          class="flex-1 font-mono border-none text-primary-foreground text-base px-4 py-1 outline-none bg-primary/80 focus:bg-primary"
        />
      </div>
      <div class="flex items-center justify-between pl-4">
        <p class="font-mono text-base flex-0 mr-4">load:</p>
        <div class="flex items-center gap-2">
          <Button
            x-on:click="loadProfile('wishlist')"
            x-bind:disabled="!profileUrl || isLoadingProfile"
            variant="ghost"
            size="default-no-padding"
          >
            <span x-text="isLoadingProfile === 'wishlist' ? 'loading…' : 'wishlist'"></span>
          </Button>
          <Button
            x-on:click="loadProfile('collection')"
            x-bind:disabled="!profileUrl || isLoadingProfile"
            variant="ghost"
            size="default-no-padding"
          >
            <span x-text="isLoadingProfile === 'collection' ? 'loading…' : 'collection'"></span>
          </Button>
        </div>
        <div class="flex-1"></div>
        <div class="flex items-center pr-4">
          <div class="flex-0 mr-2 w-4 h-4">
            <Checkbox x-model="excludeOwned" />
          </div>
          <p class="font-mono text-base">hide what I already own</p>
        </div>
      </div>
      <p
        x-show="profileError"
        x-text="profileError"
        class="px-4 py-1 font-mono text-base text-red-400"
      ></p>
    </div>

    <div class="mt-4">
      <template x-for="(item, index) in items">
        <div
          class="even:bg-primary/80 py-1 px-4 overflow-hidden text-ellipsis flex items-center"
        >
          <p
            class="font-mono text-primary-foreground truncate flex-1 w-0"
            x-text="item.url.replace('https://', '')"
          >
          </p>
          <span
            x-show="item.bpm"
            x-text="item.bpm ? `${Math.round(item.bpm)} bpm` : ''"
            class="font-mono text-base text-primary-foreground/70 mx-2"
          ></span>

          <Button x-on:click="removeItem(index)" variant="ghost">&times;</Button
          >
        </div>
      </template>
    </div>
  </div>

  <div class="w-full">
    <div class="border border-primary-foreground/20">
      <div class="flex items-center border-b border-primary-foreground/20 pl-4">
        <div class="flex-0 mr-2 w-4 h-4">
          <Checkbox x-model="isFilteringOnBpm" />
        </div>
        <div
          class="flex-1 flex items-center"
          x-bind:class="{ 'opacity-50 cursor-not-allowed': !isFilteringOnBpm }"
        >
          <p class="flex-0 font-mono text-xl mr-4">bpm filter:</p>
          <input
            type="number"
            x-model="minBpm"
            x-bind:disabled="!isFilteringOnBpm || isCrafting"
            x-bind:class="{ 'cursor-not-allowed': !isFilteringOnBpm || isCrafting }"
            placeholder="120"
            class="w-0 flex-1 font-mono border-none text-primary-foreground text-xl px-4 py-1 outline-none bg-primary/80 focus:bg-primary"
          />
          <p class="flex-0 mx-4 font-mono text-xl">to</p>
          <input
            type="number"
            x-model="maxBpm"
            x-bind:disabled="!isFilteringOnBpm || isCrafting"
            x-bind:class="{ 'cursor-not-allowed': !isFilteringOnBpm || isCrafting }"
            placeholder="140"
            class="w-0 flex-1 font-mono border-none text-primary-foreground text-xl px-4 py-1 outline-none bg-primary/80 focus:bg-primary"
          />
        </div>
      </div>

      <!-- Tag filter -->
      <div class="flex items-center border-b border-primary-foreground/20 pl-4">
        <p class="flex-0 font-mono text-xl mr-4">tags:</p>
        <input
          type="text"
          x-model="tagsInput"
          x-bind:disabled="isCrafting"
          placeholder="techno, amapiano, …"
          class="w-0 flex-1 font-mono border-none text-primary-foreground text-xl px-4 py-1 outline-none bg-primary/80 focus:bg-primary"
        />
        <div class="flex items-center pr-4">
          <template x-for="mode in ['any', 'all']">
            <Button
              x-on:click="tagMatch = mode"
              x-bind:disabled="tagMatch === mode"
              variant="ghost"
              size="default-no-padding"
              class="ml-2"
            >
              <span
                class="underline-offset-4"
                x-bind:class="{ 'underline': tagMatch === mode }"
                x-text="`match ${mode}`"
              ></span>
            </Button>
          </template>
        </div>
      </div>

      <div
        class="flex flex-col md:flex-row md:items-center border-b border-primary-foreground/20 pl-4 pr-4 md:pr-0"
      >
        <p class="flex-0 font-mono text-xl mr-4">sort by:</p>
        <div
          class="flex items-center justify-between md:justify-initial md:gap-4"
        >
          <template x-for="sort in ['relevance', 'popularity', 'random']">
            <Button
              x-on:click="sortBy = sort"
              x-bind:disabled="sortBy === sort"
              variant="ghost"
              size="default-no-padding"
            >
              <span
                class="underline-offset-4"
                x-bind:class="{ 'underline': sortBy === sort }"
                x-text="sort"></span>
            </Button>
          </template>
        </div>
      </div>

      <div class="flex items-center pl-4">
        <p>
          <span
            x-text="items.length === 1 ? `1 seed item` : `${items.length} seed items`"
          ></span>
          <span
            x-text="recommendations.length === 1 ? `& 1 rec crafted` : `& ${recommendations.length} recs crafted`"
          ></span>
        </p>
        <div class="flex-1"></div>
        <Button
          class="flex-0"
          x-on:click="getRecommendations"
          x-bind:disabled="items.length === 0 || isCrafting"
          x-text="isCrafting ? `crafting… ${elapsed}s` : (recommendations.length === 0 ? 'start crafting ->' : 're-craft ->')"
          variant="link"
        />
      </div>
    </div>

    <!-- Crafting status: visible feedback while the API works -->
    <div
      x-show="isCrafting"
      class="mt-3 border border-primary-foreground/20 p-3 font-mono text-base"
    >
      <p>
        Crafting your set…
        <span x-text="`(${elapsed}s elapsed)`"></span>
      </p>
      <p class="text-primary-foreground/70 mt-1">
        <span
          x-show="isFilteringOnBpm"
        >BPM analysis downloads &amp; decodes audio per track — this usually takes 20–60 s.</span>
        <span x-show="!isFilteringOnBpm">Should be back in a few seconds.</span>
      </p>
      <div class="mt-2 w-full h-1 bg-primary/40 overflow-hidden">
        <div class="h-1 bg-primary-foreground/60 animate-pulse w-1/3"></div>
      </div>
    </div>

    <div class="mt-4 w-full" x-bind:class="{ 'mb-12': !!recommendations.length }">
      <div class="mb-4 flex items-center justify-end text-base">
        <Button
          x-on:click="copyShareLink"
          x-show="recommendations.length > 0"
          variant="ghost"
          size="default-no-padding"
          class="text-base! mr-4"
        >
          <span x-text="shareCopied ? 'copied!' : 'copy share link'"></span>
        </Button>
        <p class="flex-0 font-mono mr-4">show as:</p>
        <div class="flex items-center justify-between md:justify-initial md:gap-4">
          <template x-for="mode in ['urls', 'previews']">
            <Button
              x-on:click="displayMode = mode"
              x-bind:disabled="displayMode === mode"
              variant="ghost"
              size="default-no-padding"
              class="text-base!"
            >
              <span
                class="underline-offset-4"
                x-bind:class="{ 'underline': displayMode === mode }"
                x-text="mode"
              ></span>
            </Button>
          </template>
        </div>
      </div>

      <div x-show="displayMode === 'urls'">
        <template x-for="rec in recommendations">
          <div class="even:bg-primary/80 py-1 px-4 flex items-center">
            <a
              x-bind:href="rec.url"
              target="_blank"
              class="font-mono text-primary-foreground truncate flex-1"
            >
              <p
                class="font-mono text-primary-foreground truncate flex-1"
                x-text="rec.url.replace('https://', '')"
              >
              </p>
            </a>
          </div>
        </template>
      </div>

      <div x-show="displayMode === 'previews'">
        <template x-for="rec in recommendations">
          <div class="w-full mb-4">
            <iframe
              x-bind:src="getBandcampEmbedUrl(rec.url, rec.id)"
              x-bind:style="getBandcampEmbedStyle(rec.url)"
              seamless
            ></iframe>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    detectBpm,
    generateRecommendations,
    getBandcampId,
    getProfileItems,
  } from '@/lib/api'

  function encodeShareState(state) {
    const json = JSON.stringify(state)
    return btoa(unescape(encodeURIComponent(json)))
  }

  function decodeShareState(encoded) {
    try {
      const json = decodeURIComponent(escape(atob(encoded)))
      return JSON.parse(json)
    } catch {
      return null
    }
  }

  document.addEventListener('alpine:init', () => {
    Alpine.data('alpineData', function () {
      return {
        url: '',
        profileUrl: this.$persist(''),
        excludeOwned: this.$persist(false),
        isLoadingProfile: '', // '' | 'wishlist' | 'collection'
        profileError: '',
        isFilteringOnBpm: this.$persist(true),
        minBpm: this.$persist(120),
        maxBpm: this.$persist(140),
        items: this.$persist([]),
        tagsInput: this.$persist(''),
        tagMatch: this.$persist('any'),
        sortBy: this.$persist('relevance'),
        displayMode: this.$persist('previews'),
        recommendations: this.$persist([]),
        isCrafting: false,
        elapsed: 0,
        _elapsedTimer: null,
        shareCopied: false,

        init() {
          // Restore from share-link hash if present
          if (window.location.hash.startsWith('#s=')) {
            const state = decodeShareState(window.location.hash.slice(3))
            if (state) {
              if (state.items) this.items = state.items
              if (state.minBpm) this.minBpm = state.minBpm
              if (state.maxBpm) this.maxBpm = state.maxBpm
              if (state.tags) this.tagsInput = state.tags
              if (state.tagMatch) this.tagMatch = state.tagMatch
              if (state.sortBy) this.sortBy = state.sortBy
              if (typeof state.isFilteringOnBpm === 'boolean')
                this.isFilteringOnBpm = state.isFilteringOnBpm
              if (state.profileUrl) this.profileUrl = state.profileUrl
              if (typeof state.excludeOwned === 'boolean')
                this.excludeOwned = state.excludeOwned
            }
          }
        },

        get parsedTags() {
          return this.tagsInput
            .split(',')
            .map((t: string) => t.trim())
            .filter((t: string) => t.length > 0)
        },

        async addItem() {
          if (this.url === '') return
          if (this.items.find((item: any) => item.url === this.url)) {
            this.url = ''
            return
          }
          try {
            const item = await getBandcampId({ url: this.url })
            this.items.push(item)
            this.url = ''
            // Fire-and-forget BPM detect; pre-fill the range once we know
            if (item.type === 'track') {
              this.detectAndApplyBpm(item, this.items.length - 1)
            }
          } catch (error) {
            console.error('Failed to add item:', error)
          }
        },

        async detectAndApplyBpm(item: any, index: number) {
          try {
            const { bpm } = await detectBpm({ id: item.id, url: item.url })
            if (!bpm) return
            // Update the item in place
            this.items[index] = { ...this.items[index], bpm }
            // Pre-fill the BPM range based on seeds — average ± 8
            const bpms = this.items
              .map((i: any) => i.bpm)
              .filter((b: any) => typeof b === 'number')
            if (bpms.length > 0) {
              const avg = bpms.reduce((a: number, b: number) => a + b, 0) / bpms.length
              this.minBpm = Math.max(60, Math.round(avg - 8))
              this.maxBpm = Math.min(200, Math.round(avg + 8))
            }
          } catch (e) {
            // BPM detection is best-effort; silent failure is fine
            console.warn('BPM detect failed for', item.url, e)
          }
        },

        async loadProfile(source: 'wishlist' | 'collection') {
          if (!this.profileUrl) return
          this.isLoadingProfile = source
          this.profileError = ''
          try {
            const fetched = await getProfileItems({
              profile_url: this.profileUrl,
              source,
              limit: 50,
            })
            // Merge into items, dedupe on url
            const existing = new Set(this.items.map((i: any) => i.url))
            const newItems = fetched.filter((i: any) => !existing.has(i.url))
            this.items = [...this.items, ...newItems]
            if (newItems.length === 0) {
              this.profileError = `No new items found in ${source}.`
            }
          } catch (e: any) {
            this.profileError = e?.response?.data?.detail ?? `Could not load ${source}.`
          } finally {
            this.isLoadingProfile = ''
          }
        },

        async removeItem(index: number) {
          this.items.splice(index, 1)
        },

        startElapsed() {
          this.elapsed = 0
          const start = Date.now()
          this._elapsedTimer = setInterval(() => {
            this.elapsed = Math.floor((Date.now() - start) / 1000)
          }, 250)
        },

        stopElapsed() {
          if (this._elapsedTimer) {
            clearInterval(this._elapsedTimer)
            this._elapsedTimer = null
          }
        },

        async getRecommendations() {
          try {
            this.recommendations = []
            this.isCrafting = true
            this.startElapsed()
            this.updateShareHash()
            const request: any = {
              set_input: { items: this.items },
              bpm_range: { min: this.minBpm, max: this.maxBpm },
              filter_bpm: this.isFilteringOnBpm,
              sort_by: this.sortBy,
              tags: this.parsedTags,
              tag_match: this.tagMatch,
            }
            if (this.excludeOwned && this.profileUrl) {
              request.exclude_owned_by_profile = this.profileUrl
            }
            this.recommendations = await generateRecommendations(request)
          } catch (error) {
            console.error('Failed to get recommendations:', error)
          } finally {
            this.stopElapsed()
            this.isCrafting = false
          }
        },

        updateShareHash() {
          const state = {
            items: this.items,
            minBpm: this.minBpm,
            maxBpm: this.maxBpm,
            isFilteringOnBpm: this.isFilteringOnBpm,
            tags: this.tagsInput,
            tagMatch: this.tagMatch,
            sortBy: this.sortBy,
            profileUrl: this.profileUrl,
            excludeOwned: this.excludeOwned,
          }
          history.replaceState(null, '', `#s=${encodeShareState(state)}`)
        },

        async copyShareLink() {
          this.updateShareHash()
          try {
            await navigator.clipboard.writeText(window.location.href)
            this.shareCopied = true
            setTimeout(() => (this.shareCopied = false), 1500)
          } catch (e) {
            console.error('clipboard write failed', e)
          }
        },

        getBandcampEmbedUrl(url: string, id: string) {
          const isAlbum = url.split('/').includes('album')
          const type = isAlbum ? 'album' : 'track'
          return `https://bandcamp.com/EmbeddedPlayer/${type}=${id}/size=large/bgcol=183344/linkcol=a5f3fc/artwork=small/transparent=true/`
        },
        getBandcampEmbedStyle(url: string) {
          const isAlbum = url.split('/').includes('album')
          const height = isAlbum ? 320 : 100
          return `border: 0; width: 100%; height: ${height}px;`
        },
      }
    })
  })
</script>
